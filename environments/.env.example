# LLM API Configuration
API_KEY=your_openrouter_api_key_here
COMMUNITY_MODEL_NAME=google/gemini-2.5-flash

# Language-specific model overrides (optional)
# Format: {"en": {"model": "model-name", "baseURL": "https://api.example.com"}, "es": {"model": "model-name-es"}}
LANGUAGE_MODEL_MAP=

# LLM Proxy Configuration
USE_LLM_PROXY=true
LLM_PROXY_URL=/api/llm-proxy

# Additional Configuration
# Maximum tokens for API requests
MAX_TOKENS=1000

# Request timeout in milliseconds
REQUEST_TIMEOUT=3000

# Retry settings
MAX_RETRIES=3