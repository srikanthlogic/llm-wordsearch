# LLM API Configuration
API_KEY=your_openrouter_api_key_here
COMMUNITY_MODEL_NAME=google/gemini-2.5-flash

# Language-specific model overrides (optional)
# Format: {"en": {"model": "model-name", "baseURL": "https://api.example.com"}, "es": {"model": "model-name-es"}}
LANGUAGE_MODEL_MAP=

# Capable Models List (optional - populated by CI/CD evaluation workflow)
# Format: JSON array of model IDs that have passed evaluation
# Example: ["google/gemini-2.0-flash-exp:free", "meta-llama/llama-3.1-8b-instruct:free"]
# If not set, a fallback list of known capable models will be used
CAPABLE_MODELS=

# LLM Proxy Configuration
USE_LLM_PROXY=true
LLM_PROXY_URL=/api/llm-proxy

# Vercel Environment Variables (for deployment)
# These will be set in Vercel dashboard:
# - API_KEY
# - COMMUNITY_MODEL_NAME
# - LANGUAGE_MODEL_MAP
# - CAPABLE_MODELS (optional, populated by CI/CD)